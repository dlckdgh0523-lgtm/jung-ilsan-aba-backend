# ──────────────────────────────────────────────────────────────
# 정지은 일산 ABA — 백엔드 환경 변수 예시
# 복사:  cp .env.example .env   (Windows: copy .env.example .env)
# ──────────────────────────────────────────────────────────────

# 런타임
NODE_ENV=development
PORT=4000
API_PREFIX=v1
TZ=Asia/Seoul

# 데이터베이스 (docker-compose 사용 시 host=db)
# 로컬 직접 실행:  postgresql://aba:aba_password@localhost:5432/aba?schema=public
DATABASE_URL=postgresql://aba:aba_password@localhost:5432/aba?schema=public

# docker-compose 의 db 컨테이너 자격증명 (compose 가 사용; 운영에선 강력한 값으로 변경)
POSTGRES_USER=aba
POSTGRES_PASSWORD=aba_password
POSTGRES_DB=aba

# JWT
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_TTL_SECONDS=43200

# 기본 관리자 (최초 시드 시 생성). 반드시 운영용 ID/비밀번호로 설정할 것.
ADMIN_DEFAULT_USERNAME=set-your-admin-id
ADMIN_DEFAULT_PASSWORD=set-a-strong-password

# CORS 허용 오리진 (쉼표 구분). 비우면 개발 모드에서 전체 허용.
CORS_ORIGINS=http://localhost:4000,http://localhost:5173

# 업로드 (로컬 디스크 저장)
UPLOAD_DIR=storage/uploads
UPLOAD_PUBLIC_BASE=/uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_IMAGE_MAX_WIDTH=1600

# 상담 신청 스팸 방지 (IP당 TTL초 내 LIMIT건)
CONSULTATION_RATE_TTL=60
CONSULTATION_RATE_LIMIT=5

# 방문자 통계: 동시접속 산정 윈도(초)
STATS_CONCURRENT_WINDOW_SECONDS=90

# 정적 프론트 서빙 (개발 편의). 운영은 Nginx가 정적 서빙 권장.
SERVE_STATIC=true
STATIC_ROOT=../aba-design-system
