# Test environment — SEPARATE database (never point at dev/prod data).
NODE_ENV=test
PORT=4099
API_PREFIX=v1
TZ=Asia/Seoul

# Dedicated test DB (created in the same Postgres container as the dev DB).
DATABASE_URL=postgresql://aba:aba_password@localhost:5432/aba_test?schema=public

JWT_SECRET=test-secret-key-at-least-32-characters-long
JWT_TTL_SECONDS=3600

ADMIN_DEFAULT_USERNAME=testadmin
ADMIN_DEFAULT_PASSWORD=testpass1234

CORS_ORIGINS=
UPLOAD_DIR=storage/uploads-test
UPLOAD_PUBLIC_BASE=/uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_IMAGE_MAX_WIDTH=1600
CONSULTATION_RATE_TTL=60
CONSULTATION_RATE_LIMIT=5
STATS_CONCURRENT_WINDOW_SECONDS=90
SERVE_STATIC=false
